# Database (Neon) — connection string, lascia vuoto e popola in .env.local
DATABASE_URL=

# Ingest XMLTV (valori di default pubblici)
XMLTV_URL=https://iptv-org.github.io/epg/guides/it/epg.xml.gz
XMLTV_SOURCE=iptv-org
XMLTV_OFFSET_MINUTES=120

# ISR on-demand revalidation — genera con: openssl rand -hex 32
REVALIDATE_TOKEN=

# Admin panel — stringa lunga custom
ADMIN_KEY=

# Sito
NEXT_PUBLIC_SITE_URL=http://localhost:3000
